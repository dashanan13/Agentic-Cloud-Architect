                    "timeoutInSeconds": {
                      "flags": 0,
                      "type": {
                        "$type": "IntegerType"
                      },
                      "description": "The monitor timeout for endpoints in this profile. This is the time that Traffic Manager allows endpoints in this profile to response to the health check."
                    },
                    "toleratedNumberOfFailures": {
                      "flags": 0,
                      "type": {
                        "$type": "IntegerType"
