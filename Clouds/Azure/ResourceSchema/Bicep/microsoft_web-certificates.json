{
  "resourceName": "App Service Certificates",
  "bicepType": "Microsoft.Web/certificates@2023-12-01",
  "terraformType": "azurerm_app_service_certificate",
  "category": "app services",
  "schemaRef": "https://learn.microsoft.com/azure/templates/microsoft.web/certificates",
  "definition": {
    "$type": "ResourceType",
    "name": "Microsoft.Web/certificates@2023-12-01",
    "body": {
      "$type": "ObjectType",
      "properties": {
        "id": {
          "flags": 10,
          "type": {
            "$type": "StringType"
          },
          "description": "The resource id"
        },
        "name": {
          "flags": 9,
          "type": {
            "$type": "StringType"
          },
          "description": "The resource name"
        },
        "type": {
          "flags": 10,
          "type": {
            "$type": "StringLiteralType",
            "value": "Microsoft.Web/certificates"
          },
          "description": "The resource type"
        },
        "apiVersion": {
          "flags": 10,
          "type": {
            "$type": "StringLiteralType",
            "value": "2023-12-01"
          },
          "description": "The resource api version"
        },
        "properties": {
          "flags": 0,
          "type": {
            "$type": "ObjectType",
            "properties": {
              "password": {
                "flags": 4,
                "type": {
                  "$type": "StringType"
                },
                "description": "Certificate password."
              },
              "friendlyName": {
                "flags": 2,
                "type": {
                  "$type": "StringType"
                },
                "description": "Friendly name of the certificate."
              },
              "subjectName": {
                "flags": 2,
                "type": {
                  "$type": "StringType"
                },
                "description": "Subject name of the certificate."
              },
              "hostNames": {
                "flags": 0,
                "type": {
                  "$type": "ArrayType",
                  "itemType": {
                    "$type": "StringType"
                  }
                },
                "description": "Host names the certificate applies to."
              },
              "pfxBlob": {
                "flags": 0,
                "type": {
                  "$type": "AnyType"
                },
                "description": "Pfx blob."
              },
              "siteName": {
                "flags": 2,
                "type": {
                  "$type": "StringType"
                },
                "description": "App name."
              },
              "selfLink": {
                "flags": 2,
                "type": {
                  "$type": "StringType"
                },
                "description": "Self link."
              },
              "issuer": {
                "flags": 2,
                "type": {
                  "$type": "StringType"
                },
                "description": "Certificate issuer."
              },
              "issueDate": {
                "flags": 2,
                "type": {
                  "$type": "StringType"
                },
                "description": "Certificate issue Date."
              },
              "expirationDate": {
                "flags": 2,
                "type": {
                  "$type": "StringType"
                },
                "description": "Certificate expiration date."
              },
              "thumbprint": {
                "flags": 2,
                "type": {
                  "$type": "StringType"
                },
                "description": "Certificate thumbprint."
              },
              "valid": {
                "flags": 2,
                "type": {
                  "$type": "BooleanType"
                },
                "description": "Is the certificate valid?."
              },
              "cerBlob": {
                "flags": 2,
                "type": {
                  "$type": "AnyType"
                },
                "description": "Raw bytes of .cer file"
              },
              "publicKeyHash": {
                "flags": 2,
                "type": {
                  "$type": "StringType"
                },
                "description": "Public key hash."
              },
              "hostingEnvironmentProfile": {
                "flags": 2,
                "type": {
                  "$type": "ObjectType",
                  "properties": {
                    "id": {
                      "flags": 0,
                      "type": {
                        "$type": "StringType"
                      },
                      "description": "Resource ID of the App Service Environment."
                    },
                    "name": {
                      "flags": 2,
                      "type": {
                        "$type": "StringType"
                      },
                      "description": "Name of the App Service Environment."
                    },
                    "type": {
                      "flags": 2,
                      "type": {
                        "$type": "StringType"
                      },
                      "description": "Resource type of the App Service Environment."
                    }
                  }
                },
                "description": "Specification for the App Service Environment to use for the certificate."
              },
              "keyVaultId": {
                "flags": 0,
                "type": {
                  "$type": "StringType"
                },
                "description": "Key Vault Csm resource Id."
              },
              "keyVaultSecretName": {
                "flags": 0,
                "type": {
                  "$type": "StringType"
                },
                "description": "Key Vault secret name."
              },
              "keyVaultSecretStatus": {
                "flags": 2,
                "type": {
                  "$type": "UnionType",
                  "elements": [
                    {
                      "$type": "StringLiteralType",
                      "value": "Initialized"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "WaitingOnCertificateOrder"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "Succeeded"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "CertificateOrderFailed"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "OperationNotPermittedOnKeyVault"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "AzureServiceUnauthorizedToAccessKeyVault"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "KeyVaultDoesNotExist"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "KeyVaultSecretDoesNotExist"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "UnknownError"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "ExternalPrivateKey"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "Unknown"
                    }
                  ]
                },
                "description": "Status of the Key Vault secret."
              },
              "serverFarmId": {
                "flags": 0,
                "type": {
                  "$type": "StringType"
                },
                "description": "Resource ID of the associated App Service plan, formatted as: \"/subscriptions/{subscriptionID}/resourceGroups/{groupName}/providers/Microsoft.Web/serverfarms/{appServicePlanName}\"."
              },
              "canonicalName": {
                "flags": 0,
                "type": {
                  "$type": "StringType"
                },
                "description": "CNAME of the certificate to be issued via free certificate"
              },
              "domainValidationMethod": {
                "flags": 0,
                "type": {
                  "$type": "StringType"
                },
                "description": "Method of domain validation for free cert"
              }
            }
          },
          "description": "Certificate resource specific properties"
        },
        "kind": {
          "flags": 0,
          "type": {
            "$type": "StringType"
          },
          "description": "Kind of resource."
        },
        "location": {
          "flags": 1,
          "type": {
            "$type": "StringType"
          },
          "description": "Resource Location."
        },
        "tags": {
          "flags": 0,
          "type": {
            "$type": "ObjectType",
            "additionalProperties": {
              "$type": "StringType"
            }
          },
          "description": "Resource tags."
        }
      }
    }
  }
}