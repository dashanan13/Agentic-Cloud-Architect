{
  "resourceName": "Production Ready Database",
  "bicepType": "Microsoft.Sql/servers/databases@2023-05-01-preview",
  "terraformType": "azurerm_mssql_database",
  "category": "general",
  "schemaRef": "https://learn.microsoft.com/azure/templates/microsoft.sql/servers/databases",
  "definition": {
    "$type": "ResourceType",
    "name": "Microsoft.Sql/servers/databases@2023-05-01-preview",
    "body": {
      "$type": "ObjectType",
      "properties": {
        "id": {
          "flags": 10,
          "type": {
