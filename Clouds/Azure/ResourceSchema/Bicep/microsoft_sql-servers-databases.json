          },
          "description": "The resource id"
        },
        "name": {
          "flags": 9,
          "type": {
            "$type": "StringType"
          },
          "description": "The resource name"
        },
        "type": {
          "flags": 10,
          "type": {
            "$type": "StringLiteralType",
            "value": "Microsoft.Sql/servers/databases"
          },
          "description": "The resource type"
        },
        "apiVersion": {
          "flags": 10,
          "type": {
            "$type": "StringLiteralType",
            "value": "2023-05-01-preview"
          },
          "description": "The resource api version"
        },
        "sku": {
          "flags": 0,
          "type": {
            "$type": "ObjectType",
            "properties": {
              "name": {
                "flags": 1,
                "type": {
                  "$type": "StringType"
                },
                "description": "The name of the SKU, typically, a letter + Number code, e.g. P3."
              },
              "tier": {
                "flags": 0,
                "type": {
                  "$type": "StringType"
                },
                "description": "The tier or edition of the particular SKU, e.g. Basic, Premium."
              },
              "size": {
                "flags": 0,
                "type": {
                  "$type": "StringType"
                },
                "description": "Size of the particular SKU"
              },
              "family": {
                "flags": 0,
                "type": {
                  "$type": "StringType"
                },
                "description": "If the service has different generations of hardware, for the same SKU, then that can be captured here."
              },
              "capacity": {
                "flags": 0,
                "type": {
                  "$type": "IntegerType"
                },
                "description": "Capacity of the particular SKU."
              }
            }
          },
          "description": "The database SKU.\r\n\r\nThe list of SKUs may vary by region and support offer. To determine the SKUs (including the SKU name, tier/edition, family, and capacity) that are available to your subscription in an Azure region, use the `Capabilities_ListByLocation` REST API or one of the following commands:\r\n\r\n```azurecli\r\naz sql db list-editions -l <location> -o table\r\n````\r\n\r\n```powershell\r\nGet-AzSqlServerServiceObjective -Location <location>\r\n````"
        },
        "kind": {
          "flags": 2,
          "type": {
            "$type": "StringType"
          },
          "description": "Kind of database. This is metadata used for the Azure portal experience."
        },
        "managedBy": {
          "flags": 2,
