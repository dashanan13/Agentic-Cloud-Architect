              "lastModifiedByType": {
                "flags": 0,
                "type": {
                  "$type": "UnionType",
                  "elements": [
                    {
                      "$type": "StringLiteralType",
                      "value": "User"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "Application"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "ManagedIdentity"
                    },
                    {
                      "$type": "StringLiteralType",
                      "value": "Key"
                    },
                    {
                      "$type": "StringType"
                    }
                  ]
