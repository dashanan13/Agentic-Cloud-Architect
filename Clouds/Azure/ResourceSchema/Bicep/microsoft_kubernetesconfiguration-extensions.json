          "flags": 10,
          "type": {
            "$type": "StringType"
          },
          "description": "The resource id"
        },
        "name": {
          "flags": 9,
          "type": {
            "$type": "StringType"
          },
          "description": "The resource name"
        },
        "type": {
          "flags": 10,
          "type": {
            "$type": "StringLiteralType",
            "value": "Microsoft.KubernetesConfiguration/extensions"
          },
          "description": "The resource type"
        },
        "apiVersion": {
          "flags": 10,
          "type": {
            "$type": "StringLiteralType",
            "value": "2023-05-01"
          },
          "description": "The resource api version"
        },
