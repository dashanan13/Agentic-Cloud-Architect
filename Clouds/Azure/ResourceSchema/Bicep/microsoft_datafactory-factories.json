                            {
                              "$type": "MaxDepthReached"
                            },
                            {
                              "$type": "MaxDepthReached"
                            },
                            {
                              "$type": "MaxDepthReached"
                            },
                            {
                              "$type": "MaxDepthReached"
                            },
                            {
                              "$type": "MaxDepthReached"
                            },
                            {
                              "$type": "MaxDepthReached"
                            }
                          ]
                        },
                        "description": "Global Parameter type."
                      },
                      "value": {
                        "flags": 1,
                        "type": {
                          "$type": "AnyType"
                        },
                        "description": "Value of parameter."
                      }
                    }
                  }
                },
                "description": "List of parameters for factory."
              },
              "encryption": {
                "flags": 0,
                "type": {
                  "$type": "ObjectType",
                  "properties": {
                    "keyName": {
                      "flags": 1,
                      "type": {
                        "$type": "StringType"
                      },
