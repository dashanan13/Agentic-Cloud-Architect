                "flags": 2,
                "type": {
                  "$type": "StringType",
                  "minLength": 36,
                  "maxLength": 36,
                  "pattern": "^[0-9a-fA-F]{8}-([0-9a-fA-F]{4}-){3}[0-9a-fA-F]{12}$"
