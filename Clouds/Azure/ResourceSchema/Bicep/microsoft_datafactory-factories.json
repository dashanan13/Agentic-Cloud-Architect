                    },
                    "vaultBaseUrl": {
                      "flags": 1,
                      "type": {
                        "$type": "StringType"
                      },
                      "description": "The url of the Azure Key Vault used for CMK."
                    },
                    "keyVersion": {
                      "flags": 0,
                      "type": {
                        "$type": "StringType"
                      },
                      "description": "The version of the key used for CMK. If not provided, latest version will be used."
                    },
                    "identity": {
                      "flags": 0,
                      "type": {
                        "$type": "ObjectType",
                        "properties": {
                          "userAssignedIdentity": {
