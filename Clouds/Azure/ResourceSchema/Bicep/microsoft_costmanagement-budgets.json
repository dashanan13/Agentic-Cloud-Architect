                      "flags": 0,
                      "type": {
                        "$type": "ObjectType",
                        "properties": {
                          "name": {
                            "flags": 1,
                            "type": {
                              "$type": "StringType"
                            },
                            "description": "The name of the column to use in comparison."
                          },
                          "operator": {
                            "flags": 1,
                            "type": {
                              "$type": "UnionType",
                              "elements": [
                                {
                                  "$type": "MaxDepthReached"
                                },
                                {
                                  "$type": "MaxDepthReached"
                                }
