              "administratorLogin": {
                "flags": 2,
                "type": {
                  "$type": "StringType"
                },
                "description": "The administrator's login name of the servers in the cluster."
              },
              "administratorLoginPassword": {
                "flags": 4,
                "type": {
                  "$type": "StringType",
                  "sensitive": true
                },
                "description": "The password of the administrator login. Required for creation."
              },
              "provisioningState": {
                "flags": 2,
                "type": {
                  "$type": "StringType"
                },
