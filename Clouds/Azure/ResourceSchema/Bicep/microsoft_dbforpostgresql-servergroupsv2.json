                "description": "The array of read replica clusters."
              },
              "earliestRestoreTime": {
                "flags": 2,
                "type": {
                  "$type": "StringType"
                },
                "description": "The earliest restore point time (ISO8601 format) for the cluster."
              },
              "privateEndpointConnections": {
                "flags": 2,
                "type": {
                  "$type": "ArrayType",
                  "itemType": {
                    "$type": "ObjectType",
