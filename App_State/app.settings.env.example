# ─────────────────────────────────────────────────────────────────────────────
# Agentic Cloud Architect (A3) – Application Settings
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to App_State/app.settings.env and fill in your values.
# The real file is gitignored and should NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Provider ──────────────────────────────────────────────────────────────
# Options: azure-foundry | ollama
MODEL_PROVIDER=azure-foundry

# ── Azure Service Principal (for Azure MCP & Foundry auth) ───────────────────
# Create via: az ad sp create-for-rbac --name "a3-app" --role Contributor
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_SUBSCRIPTION_ID=your-subscription-id-here

# ── Azure AI Foundry ─────────────────────────────────────────────────────────
# Find in Azure AI Foundry portal → your project → Overview
AI_FOUNDRY_PROJECT_NAME=your-foundry-project-name
AI_FOUNDRY_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project-name>
FOUNDRY_API_VERSION=2024-05-01-preview

# ── Foundry Model Deployments ────────────────────────────────────────────────
# Deployment names as configured in your Foundry project
FOUNDRY_MODEL_CODING=gpt-4o
FOUNDRY_MODEL_REASONING=gpt-4o
FOUNDRY_MODEL_FAST=gpt-4o-mini

# ── Foundry Agent IDs ────────────────────────────────────────────────────────
# Created by running: python Agents/AzureAIFoundry/foundry_bootstrap.py
FOUNDRY_CHAT_AGENT_ID=asst_xxxxxxxxxxxxxxxxxxxx
FOUNDRY_IAC_AGENT_ID=asst_xxxxxxxxxxxxxxxxxxxx
FOUNDRY_VALIDATION_AGENT_ID=asst_xxxxxxxxxxxxxxxxxxxx
FOUNDRY_DEFAULT_AGENT_ID=asst_xxxxxxxxxxxxxxxxxxxx

# ── Foundry Default Thread (optional, created on first run) ──────────────────
FOUNDRY_DEFAULT_THREAD_ID=thread_xxxxxxxxxxxxxxxxxxxx

# ── Ollama (local dev fallback, only needed when MODEL_PROVIDER=ollama) ───────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
